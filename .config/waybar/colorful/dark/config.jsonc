//
// WAYBAR CONFIG - Original by ML4W (https://www.ml4w.com)
// MODIFIED BY @GeodeArc
//

{
  // General Settings
  "include": "monitor.jsonc",
  "layer": "bottom",
  "margin-top": 8,
  "margin-bottom": 0,
  "margin-left": 0,
  "margin-right": 0,    
  "spacing": 0,
  "height": 46,

  // Modules Left
  "modules-left": [
      "custom/appmenu",
      "group/settings",
      "group/hardware",
      "wlr/taskbar",
      "hyprland/window"
  ],

  // Modules Center
  "modules-center": [
      "hyprland/workspaces",
      "custom/media"
  ],

  // Modules Right    
  "modules-right": [
      "network",
      "bluetooth",
      "battery",
      "pulseaudio",
      "tray",
      "custom/sidebar",
      "clock",
  ],
  
// Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": true,
    "all-outputs": false,
    "format": "{}",
    "format-icons": {
      "urgent": "´ü▒",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "*": 5
    }
  },

  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "sort-by-app-id": false,
    "on-click": "activate",
    "on-click-middle": "close",
        "all-outputs": true,
        "ignore-list": ["alactritty", "kitty", "foot"]
  },

  // Hyprland Window
  "hyprland/window": {
    "max-length": 50,
    "separate-outputs": false,
    "rewrite": {
    
      // SYS/BASE PROGRAMS
      "": 
        "´ıÖ  Hyprland",

      "~": "¯»è   Terminal",
      "zsh": "¯»è   Terminal",
      "class<kitty>": "¯»è   Terminal",

      "VLC media player": 
        "¾░ò╝   VLC Media Player",
      "(.*) - VLC media player": 
        "¾░ò╝   VLC | $1",

      "(.*) - mpv": 
        "´ı«   MPV | $1",
      
      "Authenticate": 
        "¾░╗î   Authenticate",
      
      // MISC
      "ÔÇó Discord(.*)": "Discord$1",
      "(.*)Discord(.*)": "´ç┐   $1Discord$2",
      }
  },

  // Wallpaper
  "custom/wallpaper": {
    "format": "´Ç¥",
    "on-click": "waypaper",
    "on-click-right": "waypaper --random",
    "tooltip-format": "Change wallpaper"
  },

  // Night Light
  "custom/nightlight": {
    "format": "¾░âş",
    "on-click": "pgrep hyprsunset && { pkill hyprsunset; notify-send -i night-light-disabled-symbolic -e 'Night Light Disabled'; } || { hyprsunset -t 4800 & notify-send -i night-light-symbolic -e 'Night Light Enabled'; }",
    "tooltip-format": "Night Light"
  },
  
  // Color Picker
  "custom/hyprpicker": {
    "format": "´ç╗",
    "on-click": "color=$(hyprpicker 2>/dev/null) && echo -n $color | wl-copy && notify-send -i color-select-symbolic 'Color copied to clipboard!' $color",
    "tooltip-format": "Color Picker"
  },
  
  // Settings
  "custom/settings": {
    "format": "´Çô",
    "on-click": "kitty $HOME/Dots/Scripts/Settings/settings.sh",
    "tooltip-format": "Settings"
  },

  // Rofi Application Launcher
  "custom/appmenu": {
    "format": "´äÁ   Apps",
    "on-click": "~/.config/rofi/launcher.sh",
    "tooltip-format": "Open App Launcher"
  },

  // System tray
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },

  // Clock
  "clock": {
    "format": "{:%I:%M %p}",
    "format-alt": "{:%d-%m-%Y}",
    "on-click-right": "gnome-clocks",
    "tooltip": true,
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
                    "mode"          : "month",
                    "mode-mon-col"  : 3,
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#FFFFFF'>{}</span>",
                              "days":       "<span color='#9c9c9c'>{}</span>",
                              "weeks":      "<span color='#9c9c9c'>W{}</span>",
                              "weekdays":   "<span color='#FFFFFF'>{}</span>",
                              "today":      "<span color='#FFFFFF'><b>{}</b></span>"
                              }
                    },
        "actions":  {
                    "on-click-middle": "mode",
                    "on-scroll-up": "shift_down",
                    "on-scroll-down": "shift_up"
                    }
    },

  // System
  "custom/system": {
    "format": "´Æ╝",
    "on-click": "resources",
    "tooltip-format": "Open Resources"
  },

  // CPU
  "cpu": {
    "interval": 5,
    "format": "C {usage}% ",
  },

  // Memory
  "memory": {
    "interval": 5,
    "format": "- M {}% ",
  },

  // Harddisc space used
  "disk": {
    "interval": 5,
    "format": "- D {percentage_used}% ",
    "path": "/",
  },

  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": true
    },
    "modules": ["custom/system", "cpu", "memory", "disk"]
  },

  // Group Settings
  "group/settings": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/settings",
      "custom/nightlight",
      "custom/hyprpicker",
      "custom/wallpaper"
    ]
  },

  // Network
  "network": {
    "format": "¾░▓ø  Offline",
    "format-wifi": "´ç½ ",
    "format-ethernet": "¾░êÇ ¾░êü",
    "format-linked": "¾░êÇ ¾░êü",
    "format-disconnected": "¾░▓ø  Offline",
    "tooltip-format": "¾░êÇ  {ifname} via {gwaddri}",
    "tooltip-format-wifi": "´ç½   Connected \n\nIP: {ipaddr}\nStrength: {signalStrength}%\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "¾░êÇ  {ifname}\n\nIP: {ipaddr}\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "nm-connection-editor",
    "on-click-right": "kitty nmtui"
  },

  // Battery
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "¯║í   {capacity}%",
    "format-plugged": "´çĞ  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-icons": ["´ëä ", "´ëâ ", "´ëé ", "´ëü ", "´ëÇ "]
  },

  // Pulseaudio
  "pulseaudio": {
    "states": {
      "normal": 100,
      "warning": 150,
      "danger": 250
    },
    "scroll-step": 1,
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon}  {volume}% ´èö",
    "format-bluetooth-muted": "´ÇĞ  Muted ´èö",
    "format-muted": "´ÇĞ  Muted",
    "format-source": "{volume}% ´ä░",
    "format-source-muted": "´ä▒",
    "format-warning": "{icon}  {volume}%  ´ü▒ ",
    "format-danger": "{icon}  {volume}%  ´ö░ ",
    "format-icons": {
      "headphone": "´ÇÑ ",
      "hands-free": "´ÇÑ ",
      "headset": "¯╣Ö ",
      "phone": "´éò ",
      "portable": "´éò ",
      "car": "´å╣ ",
      "default": ["´ÇĞ ", "´Çğ  ", "´Ç¿  ", "´Ç¿  "]
    },
    "tooltip-format": "{desc}\n\nSpeaker: {volume}% ¾░ôâ\nMic: {format_source}",
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
  },

  // Bluetooth
  "bluetooth": {
    "format": "´èô",
    "format-disabled": "´èô ´æğ",
    "format-off": "´èô Off",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": "",
  "tooltip-format": "´èô {controller_alias}\n\n{num_connections} connected",
  "tooltip-format-connected": "´èô {controller_alias}\n\n{num_connections} connected",
  "tooltip-format-enumerate-connected": "´èô {device_alias}",
  "tooltip-format-enumerate-connected-battery": "´èô {device_alias}\t{device_battery_percentage}%"
  },

  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  // Media
  "custom/media": {
    "interval": 1,
    "max-length": 40,
    "exec": "~/Dots/Scripts/Hyprland/mediaexec.sh",
    "on-click": "~/Dots/Scripts/Hyprland/mediatoggle.sh"
  },

  // Backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "¯Äı",
      "¯Åö",
      "¯Åô",
      "¯ÅÆ",
      "¯Åæ",
      "¯ÅÉ",
      "¯ÅÅ",
      "¯ÅÄ",
      "¯Åı",
      "¯Åî",
      "¯Åï",
      "¯Åè",
      "¯Åë",
      "¯Åê",
      "¯Äø"
    ],
    "scroll-step": 1

  // Notifs
  },
  "custom/sidebar": {
      "format": "¾▒ù╝",
      "tooltip-format": "Sidebar",
      "on-click": "swaync-client -t",
  }
}
